{
  "name": "excalidraw-persist",
  "version": "0.18.0-persist.7",
  "description": "Self-hostable Excalidraw server-side persistence, and multi-boards",
  "private": true,
  "scripts": {
    "dev": "pnpm -r run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\" && pnpm -r run format",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "excalidraw",
    "drawing"
  ],
  "author": "",
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.11",
      "tar-fs": ">=2.1.4",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "nanoid@<3.3.8": ">=3.3.8",
      "nanoid": ">=5.0.9",
      "lodash-es": ">=4.18.1",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "dompurify": ">=3.3.3",
      "vite": ">=7.3.2",
      "immutable": ">=5.1.5",
      "picomatch": ">=4.0.4",
      "brace-expansion@>=2 <3": ">=2.0.2",
      "brace-expansion@>=1 <2": ">=1.1.12",
      "brace-expansion@>=4 <5": ">=5.0.5",
      "brace-expansion@>=3 <4": ">=5.0.5",
      "flatted": ">=3.4.2",
      "@tootallnate/once": ">=3.0.1",
      "on-headers": ">=1.1.0",
      "diff": ">=5.2.2",
      "qs": ">=6.14.2",
      "balanced-match": ">=1.0.2",
      "brace-expansion": ">=5.0.5",
      "cookie": ">=0.7.0",
      "path-to-regexp@<1": ">=0.1.12",
      "path-to-regexp@>=8 <9": ">=8.4.2",
      "mermaid": ">=10.9.4",
      "ajv": ">=6.14.0"
    }
  },
  "devDependencies": {
    "prettier": "^3.0.0"
  }
} 
